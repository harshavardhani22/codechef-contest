import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int X = sc.nextInt(); // Alice primary
        int Y = sc.nextInt(); // Alice secondary
        int A = sc.nextInt(); // Bob primary
        int B = sc.nextInt(); // Bob secondary

        // Compare primary scores
        if (X > A) {
            System.out.println("Alice");
        } else if (A > X) {
            System.out.println("Bob");
        }
        // If primary scores are equal
        else {
            if (Y > B) {
                System.out.println("Alice");
            } else if (B > Y) {
                System.out.println("Bob");
            }
            // If both scores are equal
            else {
                System.out.println("Alice");
            }
        }
    }
}
